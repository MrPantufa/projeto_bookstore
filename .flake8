[flake8]
# Mantém um limite razoável p/ Django
max-line-length = 120
# Compatibilidade com black
extend-ignore = E203, W503

# Não analisar caches, envs e migrations
exclude =
    .git,
    __pycache__,
    env,
    venv,
    .venv,
    */migrations/*

# Ignora alertas comuns em arquivos especiais:
# - settings.py: linhas longas
# - admin.py: imports só para registro
# - __init__.py: re-export, ordem de import, linhas longas/dobras
# - tests/*: linhas longas e imports de fixtures
per-file-ignores =
    */settings.py:E501
    */admin.py:F401
    */__init__.py:F401,E402,E501,E303
    **/tests/**:E501,F401
